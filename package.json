{
  "name": "cesar-extension",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node build.js --watch",
    "build": "node build.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0"
  }
}
